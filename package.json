{
  "name": "lates-factium-ai-v3",
  "private": true,
  "version": "1.3.3",
  "description": "Factium AI - Advanced Fact-Checking and Bias Analysis",
  "author": "Factium AI Team",
  "main": "main.js",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist dist_electron && vite build --base=./",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "1.30.0",
    "@tailwindcss/vite": "4.2.2",
    "autoprefixer": "10.4.27",
    "driver.js": "1.4.0",
    "idb": "8.0.3",
    "lucide-react": "0.263.1",
    "motion": "12.4.7",
    "postcss": "8.5.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "9.0.3",
    "recharts": "2.15.1",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "rimraf": "^6.1.3",
    "typescript": "5.8.2",
    "vite": "6.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "productName": "Factium AI",
    "appId": "com.factium.ai.v111",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "dist_electron/**/*",
      "backend/**/*",
      "main.js",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
